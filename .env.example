# Anthropic API Key для OCR распознавания чеков
# Получить на: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Только для старого локального Vite-прокси. В Vercel лучше использовать ANTHROPIC_API_KEY.
VITE_ANTHROPIC_API_KEY=sk-ant-...

# Опционально: можно переопределить модель OCR без изменения кода.
ANTHROPIC_OCR_MODEL=claude-haiku-4-5-20251001
